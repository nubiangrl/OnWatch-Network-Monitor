            </div>

            <div id="recentEventItems">
            {% if recent_events %}
            <ul>
                {% for event in recent_events %}
                <li>{{ event }}</li>
                {% endfor %}
            </ul>
            {% else %}
            <p>No events recorded yet.</p>
            {% endif %}
            </div>
        </section>

    </aside>

</div>

<footer class="footer-bar">
    Real-time Monitoring • Cisco SNMP Links • Event Logging • Home Network Health
</footer>

<script>
function setTextIfPresent(elementId, value) {
    var element = document.getElementById(elementId);
    if (element) {
        element.textContent = value;
    }
}

function setHTMLIfPresent(elementId, value) {
    var element = document.getElementById(elementId);
    if (element) {
        element.innerHTML = value;
    }
}

function showPanel(panelId) {
    hidePanels();
    document.getElementById(panelId).classList.remove("hidden");
}

function hidePanels() {
    document.getElementById("addPanel").classList.add("hidden");
    document.getElementById("maintenancePanel").classList.add("hidden");
    document.getElementById("editPanel").classList.add("hidden");
    document.getElementById("removePanel").classList.add("hidden");
}
</script>


<script>
window.dismissCriticalPopup = function () {
    var popup = document.getElementById("criticalAlertPopup");

    if (!popup) {
        return false;
    }

    var alertId = popup.getAttribute("data-alert-id") || "";
    var dismissedAlerts = [];

    try {
        dismissedAlerts = JSON.parse(
            localStorage.getItem("dismissedCriticalPopupAlerts") || "[]"
        );
    } catch (e) {
        dismissedAlerts = [];
    }

    if (alertId && dismissedAlerts.indexOf(alertId) === -1) {
        dismissedAlerts.push(alertId);
    }

    localStorage.setItem(
        "dismissedCriticalPopupAlerts",
        JSON.stringify(dismissedAlerts)
    );

    popup.style.display = "none";

    return false;
};

document.addEventListener("DOMContentLoaded", function () {
    var popup = document.getElementById("criticalAlertPopup");

    if (!popup) {
        return;
    }

    var alertId = popup.getAttribute("data-alert-id") || "";
    var dismissedAlerts = [];

    try {
        dismissedAlerts = JSON.parse(
            localStorage.getItem("dismissedCriticalPopupAlerts") || "[]"
        );
    } catch (e) {
        dismissedAlerts = [];
    }

    if (alertId && dismissedAlerts.indexOf(alertId) !== -1) {
        popup.style.display = "none";
    }
});
</script>


<script>
document.addEventListener("DOMContentLoaded", function () {

    const alerts = [
        {% for alert in alerts %}
        {
            id: "{{ alert.id }}",
            severity: "{{ alert.severity }}",
            device: "{{ alert.device }}",
            problem: "{{ alert.problem }}",
            time: "{{ alert.time }}"
        }{% if not loop.last %},{% endif %}
        {% endfor %}
    ];

    const voiceActions = document.querySelector(".voice-alert-actions");

    if (voiceActions && !document.getElementById("enableBrowserNotifications")) {

        const btn = document.createElement("button");
        btn.type = "button";
        btn.id = "enableBrowserNotifications";
        btn.className = "voice-test-btn";
        btn.textContent = "Enable Browser Notifications";

        voiceActions.appendChild(btn);

        if (!document.getElementById("browserNotificationSecureNote")) {
            const secureNote = document.createElement("div");
            secureNote.id = "browserNotificationSecureNote";
            secureNote.textContent = "* Browser notifications require a secure (HTTPS) site.";
            secureNote.style.width = "100%";
            secureNote.style.fontSize = "11px";
            secureNote.style.color = "#9fb3c8";
            secureNote.style.marginTop = "6px";
            secureNote.style.textAlign = "right";
            secureNote.style.lineHeight = "1.1";

            voiceActions.appendChild(secureNote);
        }

        btn.addEventListener("click", async function () {

            if (!("Notification" in window)) {
                alert("Browser notifications are not supported.");
                return;
            }

            const permission = await Notification.requestPermission();

            if (permission === "granted") {
                new Notification("Home Network Monitor", {
                    body: "Browser notifications enabled successfully."
                });
            }
        });
    }

    if (!("Notification" in window)) return;
    if (Notification.permission !== "granted") return;

    let sentAlerts = [];

    try {
        sentAlerts = JSON.parse(
            localStorage.getItem("browserNotificationAlerts") || "[]"
        );
    } catch(e) {
        sentAlerts = [];
    }

    alerts.forEach(function(alert) {

        if (alert.severity !== "CRITICAL") return;

        if (!sentAlerts.includes(alert.id)) {

            new Notification("🚨 Critical Alert", {
                body:
                    alert.device + " - " +
                    alert.problem
            });

            sentAlerts.push(alert.id);
        }
    });

    localStorage.setItem(
        "browserNotificationAlerts",
        JSON.stringify(sentAlerts)
    );
});
</script>

{% include "voice_alerts.html" %}


<script>
/* PHASE 8A - SMART BACKGROUND REFRESH */
(function () {
    const REFRESH_SECONDS = 20;
    let refreshPaused = false;

    function setText(id, value) {
        const el = document.getElementById(id);
        if (el) el.textContent = value;
    }

    function setHTML(id, value) {
        const el = document.getElementById(id);
        if (el) el.innerHTML = value;
    }

    function formsAreOpenOrFocused() {
        const active = document.activeElement;
        const typing = active && ["INPUT", "SELECT", "TEXTAREA"].includes(active.tagName);

        // Phase 11D refresh-state fix:
        // Do not keep Smart Refresh paused just because a panel is open after a form submit.
        // Only pause while the user is actively typing/selecting OR while refreshPaused is explicitly true.
        return refreshPaused || typing;
    }

    function updateSmartRefreshStatus(message, paused) {
        const el = document.getElementById("smartRefreshStatus");
        if (!el) return;
        el.textContent = message;
        el.classList.toggle("paused", !!paused);
    }

    function updateSystemState(isGood) {
        const stateBox = document.getElementById("systemStateBox");
        const banner = document.getElementById("statusBanner");

        if (stateBox) {
            stateBox.className = isGood ? "system-state good-state" : "system-state bad-state";
            stateBox.innerHTML = isGood ? "✅<br>All Systems Operational" : "⚠<br>Attention Required";
        }

        if (banner) {
            banner.className = isGood ? "status-banner banner-good" : "status-banner banner-bad dashboard-critical-flash";
            banner.innerHTML = isGood ? "EVERYTHING IS UP & RUNNING ✅" : "SOMETHING IS DOWN ⚠";
        }
    }

    async function refreshDashboardData() {
        if (formsAreOpenOrFocused()) {
            updateSmartRefreshStatus("Smart Refresh: Paused while editing", true);
            return;
        }

        try {
            const response = await fetch("/api/dashboard-data", { cache: "no-store" });
            if (!response.ok) throw new Error("API request failed");

            const data = await response.json();

            setText("lastFullScanValue", data.last_full_scan);
            setText("networkHealthValue", data.health + "%");
            setText("devicesOnlineValue", data.up);
            setText("devicesOfflineValue", data.down);
            setText("switchLinksUpValue", data.switch_up);
            setText("switchLinksDownValue", data.switch_down);
            setText("totalAlertsValue", data.total_alerts);
            setText("activeCriticalValue", data.critical_count);

            if (data.lifecycle_summary && data.lifecycle_summary.counts) {
                setText("lifecycleUpValue", data.lifecycle_summary.counts.UP ?? 0);
                setText("lifecycleSleepingValue", data.lifecycle_summary.counts.SLEEPING ?? 0);
                setText("lifecycleProvisioningValue", data.lifecycle_summary.counts.PROVISIONING ?? 0);
                setText("lifecycleMaintenanceValue", data.lifecycle_summary.counts.MAINTENANCE ?? 0);
                setText("lifecycleDownValue", data.lifecycle_summary.counts.DOWN ?? 0);
                setText("lifecycleOfflineValue", data.lifecycle_summary.counts.OFFLINE ?? 0);
                setText("nocSleepingValue", data.lifecycle_summary.counts.SLEEPING ?? 0);
            }

            setText("internetUptimeValue", data.uptime_stats.network_uptime);
            setText("todayInternetOutagesValue", data.uptime_stats.today_outages);
            setText("longestInternetOutageValue", data.uptime_stats.longest_outage);
            setText("lastInternetOutageValue", data.uptime_stats.last_outage);

            setText("todayAvailabilityValue", data.availability_report.today.availability);
            setText("weekAvailabilityValue", data.availability_report.week.availability);
            setText("monthAvailabilityValue", data.availability_report.month.availability);
            setText("last30AvailabilityValue", data.availability_report.last_30_days.availability);

            if (data.network_intelligence) {
                setText("niInfrastructureValue", data.network_intelligence.category_counts.infrastructure);
                setText("niPhysicalValue", data.network_intelligence.category_counts.physical);
                setText("niVirtualValue", data.network_intelligence.category_counts.virtual);
                setText("niAverageLatencyValue", data.network_intelligence.average_latency);
                setText("niSwitchHealthValue", data.network_intelligence.switch_link_health);
                setText("niActiveAlertsValue", data.network_intelligence.active_alert_count);
            }

            if (data.network_intelligence_html) {
                setHTML("networkIntelligenceLatencyRows", data.network_intelligence_html.latency_rows);
                setHTML("networkIntelligenceHistoryRows", data.network_intelligence_html.history_rows);
                setHTML("networkIntelligenceLinkRows", data.network_intelligence_html.link_rows);
            }

            setText("diagnosisText", data.diagnosis);

            setHTML("deviceStatusRows", data.device_rows);
            setHTML("routerInterfaceRows", data.router_rows);
            setHTML("switchLinkRows", data.switch_rows);
            setHTML("ciscoEventRows", data.cisco_event_rows);
            setHTML("recentEventItems", data.recent_event_items);

            updateSystemState(data.system_good);

            if (typeof window.updateNocCommandCenter === "function") {
                window.updateNocCommandCenter(data);
            }

            if (typeof window.updateNocHistoricalIntelligence === "function") {
                window.updateNocHistoricalIntelligence(data);
            }

            updateSmartRefreshStatus("Smart Refresh: Active • Last update " + new Date().toLocaleTimeString(), false);

        } catch (error) {
            updateSmartRefreshStatus("Smart Refresh: API error - check logs", true);
            console.error("Smart Refresh failed:", error);
        }
    }

    window.pauseSmartRefresh = function () {
        refreshPaused = true;
        updateSmartRefreshStatus("Smart Refresh: Paused while editing", true);
    };

    window.resumeSmartRefresh = function () {
        refreshPaused = false;
        refreshDashboardData();
    };

    const originalShowPanel = window.showPanel;
    window.showPanel = function (panelId) {
        if (typeof originalShowPanel === "function") originalShowPanel(panelId);
        window.pauseSmartRefresh();
    };

    const originalHidePanels = window.hidePanels;
    window.hidePanels = function () {
        if (typeof originalHidePanels === "function") originalHidePanels();
        window.resumeSmartRefresh();
    };

    // Phase 11D refresh-state fix:
    // Any form submit means editing is complete. Clear the pause state before the browser posts.
    document.addEventListener("submit", function () {
        refreshPaused = false;
        sessionStorage.setItem("onWatchRefreshResume", "1");
        updateSmartRefreshStatus("Smart Refresh: Resuming...", false);
    });

    // If the page reloads after a successful POST, force Smart Refresh back to active.
    if (sessionStorage.getItem("onWatchRefreshResume") === "1") {
        sessionStorage.removeItem("onWatchRefreshResume");
        refreshPaused = false;
        setTimeout(function () {
            updateSmartRefreshStatus("Smart Refresh: Active • Last update " + new Date().toLocaleTimeString(), false);
            refreshDashboardData();
        }, 500);
    }

    document.addEventListener("focusin", function (event) {
        if (event.target && ["INPUT", "SELECT", "TEXTAREA"].includes(event.target.tagName)) {
            window.pauseSmartRefresh();
        }
    });

    document.addEventListener("focusout", function () {
        setTimeout(function () {
            if (!formsAreOpenOrFocused()) window.resumeSmartRefresh();
        }, 500);
    });

    setInterval(refreshDashboardData, REFRESH_SECONDS * 1000);
    setTimeout(refreshDashboardData, 3000);
})();
</script>


<script>
(function () {
    function refreshPhase10BIntelligence() {
        fetch("/api/dashboard-data")
            .then(function (response) {
                return response.json();
            })
            .then(function (data) {
                if (!data || !data.network_intelligence) {
                    return;
                }

                var ni = data.network_intelligence;
                var niHtml = data.network_intelligence_html || {};

                setTextIfPresent("niScoreValue", (ni.intelligence_score ?? "N/A") + "%");
                setTextIfPresent("niScoreLabel", ni.score_label || "N/A");
                setTextIfPresent("niGradeValue", ni.network_grade || "N/A");
                setTextIfPresent("niWeakestLinkValue", ni.weakest_link || "N/A");
                setTextIfPresent("niRecommendationValue", ni.recommendation || "N/A");
                setTextIfPresent("niSummaryValue", ni.summary || "N/A");

                setHTMLIfPresent("networkIntelligenceRiskRows", niHtml.risk_rows || "");

                var scoreElement = document.getElementById("niScoreValue");
                var gradeElement = document.getElementById("niGradeValue");

                if (scoreElement) {
                    scoreElement.classList.remove("green", "blue", "orange", "red");

                    var score = parseInt(ni.intelligence_score || 0, 10);

                    if (score >= 90) {
                        scoreElement.classList.add("green");
                    } else if (score >= 80) {
                        scoreElement.classList.add("blue");
                    } else if (score >= 70) {
                        scoreElement.classList.add("orange");
                    } else {
                        scoreElement.classList.add("red");
                    }
                }

                if (gradeElement) {
                    gradeElement.classList.remove("green", "blue", "orange", "red");

                    var grade = ni.network_grade || "";

                    if (grade === "A+" || grade === "A") {
                        gradeElement.classList.add("green");
                    } else if (grade === "B") {
                        gradeElement.classList.add("blue");
                    } else if (grade === "C" || grade === "D") {
                        gradeElement.classList.add("orange");
                    } else {
                        gradeElement.classList.add("red");
                    }
                }
            })
            .catch(function () {
            });
    }

    refreshPhase10BIntelligence();
    setInterval(refreshPhase10BIntelligence, 20000);
})();
</script>


<script>
(function () {
    function refreshPhase10CPredictiveIntelligence() {
        fetch("/api/dashboard-data")
            .then(function (response) {
                return response.json();
            })
            .then(function (data) {
                if (!data || !data.phase10c) {
                    return;
                }

                var p10c = data.phase10c;
                var p10cHtml = data.phase10c_html || {};
                var forecast = p10c.forecast || {};

                setTextIfPresent("phase10cRiskLevel", forecast.risk_level || "N/A");
                setTextIfPresent("phase10cRiskPoints", forecast.risk_points ?? "N/A");
                setTextIfPresent("phase10cForecastText", forecast.forecast_text || "N/A");
                setTextIfPresent("phase10cAverageStability", (forecast.average_stability ?? "N/A") + "%");
                setTextIfPresent("phase10cInternetTrendEvents", forecast.internet_trend_events ?? "N/A");

                setHTMLIfPresent("phase10cStabilityRows", p10cHtml.stability_rows || "");
                setHTMLIfPresent("phase10cReliableRows", p10cHtml.reliable_rows || "");
                setHTMLIfPresent("phase10cPredictiveRows", p10cHtml.predictive_rows || "");

                var riskElement = document.getElementById("phase10cRiskLevel");

                if (riskElement) {
                    riskElement.classList.remove("phase10c-low", "phase10c-moderate", "phase10c-elevated", "phase10c-high");

                    var riskLevel = forecast.risk_level || "";

                    if (riskLevel === "LOW") {
                        riskElement.classList.add("phase10c-low");
                    } else if (riskLevel === "MODERATE") {
                        riskElement.classList.add("phase10c-moderate");
                    } else if (riskLevel === "ELEVATED") {
                        riskElement.classList.add("phase10c-elevated");
                    } else if (riskLevel === "HIGH") {
                        riskElement.classList.add("phase10c-high");
                    }
                }
            })
            .catch(function () {
            });
    }

    refreshPhase10CPredictiveIntelligence();
    setInterval(refreshPhase10CPredictiveIntelligence, 30000);
})();
</script>


<script>
(function () {
    function setHealthPillClass(elementId, healthClass) {
        var element = document.getElementById(elementId);
        if (!element) {
            return;
        }

        element.classList.remove("green", "blue", "orange", "red");
        element.classList.add(healthClass || "orange");
    }

    function refreshLanInternetHealthSplit() {
        fetch("/api/dashboard-data")
            .then(function (response) {
                return response.json();
            })
            .then(function (data) {
                if (!data || !data.lan_internet_health) {
                    return;
                }

                var split = data.lan_internet_health;
                var lan = split.lan || {};
                var internet = split.internet || {};

                setTextIfPresent("lanHealthLabel", lan.health_label || "N/A");
                setTextIfPresent("lanWeakestValue", lan.weakest_lan || "N/A");
                setTextIfPresent("lanAverageLatencyValue", lan.average_latency || "N/A");
                setTextIfPresent("lanOnlineValue", (lan.online_devices ?? "0") + "/" + (lan.total_devices ?? "0"));
                setTextIfPresent("lanSwitchHealthValue", lan.switch_health || "N/A");

                setTextIfPresent("internetHealthLabel", internet.health_label || "N/A");
                setTextIfPresent("internetStateValue", internet.state || "N/A");
                setTextIfPresent("internetLatencyValue", internet.average_latency || "N/A");
                setTextIfPresent("internetAvailabilityTodayValue", internet.availability_today || "N/A");
                setTextIfPresent("internetOutagesTodaySplitValue", internet.outages_today ?? "0");
                setHTMLIfPresent("internetTargetRows", internet.target_rows || "");

                setHealthPillClass("lanHealthLabel", lan.health_class);
                setHealthPillClass("internetHealthLabel", internet.health_class);
            })
            .catch(function () {});
    }

    refreshLanInternetHealthSplit();
    setInterval(refreshLanInternetHealthSplit, 30000);
})();
</script>


