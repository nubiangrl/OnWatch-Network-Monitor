                    <td>{{ info.latency }}</td>
                    <td>{{ info.last_checked }}</td>
                </tr>
                {% endfor %}
                </tbody>
            </table>
        </section>

        <div class="split-panels">

            <section class="panel">
                <h2>Cisco Router Interfaces</h2>

                <table>
                    <tr>
                        <th>Interface</th>
