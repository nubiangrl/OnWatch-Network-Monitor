                        {% elif alert.severity == "WARNING" %}
                            <span class="severity-badge warning">🟡 Warning</span>
                        {% else %}
                            <span class="severity-badge info">🔵 Info</span>
                        {% endif %}
                    </td>
                    <td>{{ alert.device }}</td>
                    <td>{{ alert.problem }}</td>
                    <td>{{ alert.time }}</td>
                </tr>
                {% endfor %}
            </table>
        </section>
        {% endif %}

