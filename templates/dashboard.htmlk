<script>
const ONWATCH_EXISTING_DEVICES = {{ all_devices | tojson }};
const ONWATCH_DEVICE_TYPES = {{ device_types | tojson }};
const ONWATCH_SWITCH_PORTS = {{ all_switch_ports | tojson }};
const ONWATCH_MANAGED_PORTS = {{ managed_ports | tojson }};

function getSelectedProvisioningType() {
    var selected = document.querySelector('input[name="provisioning_type"]:checked');
    return selected ? selected.value : "physical";
}

function selectProvisioningType(typeValue) {
    var input = document.querySelector('input[name="provisioning_type"][value="' + typeValue + '"]');
    if (input && !input.checked) {
        input.checked = true;
    }
}

function setRequired(selector, enabled) {
    var item = document.querySelector(selector);
    if (item) {
        item.required = enabled;
    }
}

function findExistingIpOwner(ipAddress) {
    if (!ipAddress) {
        return "";
    }

    for (var deviceName in ONWATCH_EXISTING_DEVICES) {
        if (ONWATCH_EXISTING_DEVICES[deviceName] === ipAddress) {
            return deviceName;
        }
    }

    return "";
}

function suggestProvisioningTypeFromName(deviceName) {
    var text = (deviceName || "").toLowerCase();

    if (!text) {
        return null;
    }

    if (text.includes("vm") || text.includes("virtual") || text.includes("home assistant") || text.includes("docker") || text.includes("ubuntu vm")) {
        return {
            type: "virtual",
            message: "🧩 Suggestion: This looks like a Virtual Machine."
        };
    }

    if (text.includes("firewall") || text.includes("router") || text.includes("switch") || text.includes("modem") || text.includes("gateway") || text.includes("access point") || text.includes("ap ") || text.includes("ups") || text.includes("dns") || text.includes("dhcp") || text.includes("vpn") || text.includes("cisco asa")) {
        return {
            type: "infrastructure",
            message: "🛡 Suggestion: This looks like an Infrastructure device."
        };
    }

    if (text.includes("printer") || text.includes("camera") || text.includes("mac") || text.includes("laptop") || text.includes("desktop") || text.includes("pc") || text.includes("server") || text.includes("nas")) {
        return {
            type: "physical",
            message: "🖥 Suggestion: This looks like a Physical device."
        };
    }

    return null;
}

function applyInfrastructureRoleSuggestion(deviceName) {
    var roleSelect = document.getElementById("provisionInfrastructureRole");
    if (!roleSelect) {
        return;
    }

    var text = (deviceName || "").toLowerCase();

    var role = "";
    if (text.includes("firewall") || text.includes("asa")) role = "firewall";
    else if (text.includes("router")) role = "router";
    else if (text.includes("switch")) role = "switch";
    else if (text.includes("modem") || text.includes("gateway")) role = "modem";
    else if (text.includes("access point") || text.includes(" ap")) role = "access_point";
    else if (text.includes("ups") || text.includes("battery")) role = "ups";
    else if (text.includes("dns")) role = "dns";
    else if (text.includes("dhcp")) role = "dhcp";
    else if (text.includes("vpn")) role = "vpn";

    if (role && !roleSelect.value) {
        roleSelect.value = role;
    }
}

function applyPhysicalTypeSuggestion(deviceName) {
    var physicalType = document.getElementById("physicalDeviceType");
    if (!physicalType) {
        return;
    }

    var text = (deviceName || "").toLowerCase();

    if (text.includes("chromebook") || text.includes("chrome book")) physicalType.value = "Chromebook";
    else if (text.includes("printer")) physicalType.value = "Printer";
    else if (text.includes("camera")) physicalType.value = "Camera";
    else if (text.includes("mac")) physicalType.value = "Mac";
    else if (text.includes("laptop")) physicalType.value = "Laptop";
    else if (text.includes("desktop")) physicalType.value = "Desktop PC";
    else if (text.includes("windows") || text.includes("pc")) physicalType.value = "Desktop PC";
    else if (text.includes("server") || text.includes("nas") || text.includes("omv")) physicalType.value = "Server / NAS";
    else if (text.includes("tv")) physicalType.value = "TV";
    else if (text.includes("xbox") || text.includes("playstation") || text.includes("gaming")) physicalType.value = "Gaming Console";
    else if (text.includes("phone") || text.includes("iphone") || text.includes("android") || text.includes("mobile")) physicalType.value = "Mobile Device";
    else physicalType.value = "Other Endpoint";
}

function updateProvisioningFields(skipSuggestion) {
    var deviceNameInput = document.getElementById("provisionDeviceName");
    var ipInput = document.getElementById("provisionIpAddress");
    var deviceName = deviceNameInput ? deviceNameInput.value.trim() : "";
    var ipAddress = ipInput ? ipInput.value.trim() : "";

    if (!skipSuggestion && deviceName) {
        var suggestion = suggestProvisioningTypeFromName(deviceName);
        var suggestionBox = document.getElementById("provisionSuggestionBox");

        if (suggestion) {
            selectProvisioningType(suggestion.type);

            if (suggestion.type === "infrastructure") {
                applyInfrastructureRoleSuggestion(deviceName);
            }

            if (suggestion.type === "physical") {
                applyPhysicalTypeSuggestion(deviceName);
            }

            if (suggestionBox) {
                suggestionBox.textContent = suggestion.message;
                suggestionBox.classList.remove("hidden");
            }
        } else if (suggestionBox) {
            suggestionBox.classList.add("hidden");
            suggestionBox.textContent = "";
        }
    }

    var selectedType = getSelectedProvisioningType();

    var physicalFields = document.getElementById("physicalProvisionFields");
    var virtualFields = document.getElementById("virtualProvisionFields");
    var infrastructureFields = document.getElementById("infrastructureProvisionFields");

    if (physicalFields) {
        physicalFields.classList.toggle("hidden", selectedType !== "physical");
    }

    if (virtualFields) {
        virtualFields.classList.toggle("hidden", selectedType !== "virtual");
    }

    if (infrastructureFields) {
        infrastructureFields.classList.toggle("hidden", selectedType !== "infrastructure");
    }

    setRequired('select[name="switch_port"]', selectedType === "physical");
    setRequired('select[name="hosted_by"]', selectedType === "virtual");
    setRequired('select[name="infrastructure_role"]', selectedType === "infrastructure");

    var switchPortSelect = document.getElementById("provisionSwitchPort");
    var hostedBySelect = document.getElementById("provisionHostedBy");
    var infrastructureRoleSelect = document.getElementById("provisionInfrastructureRole");
    var physicalTypeSelect = document.getElementById("physicalDeviceType");
    var submitButton = document.getElementById("provisionSubmitButton");
    var warningBox = document.getElementById("provisionLiveWarning");

    if (deviceNameInput) {
        if (selectedType === "physical") {
            deviceNameInput.placeholder = "Example: Security Camera 01";
        } else if (selectedType === "virtual") {
            deviceNameInput.placeholder = "Example: Home Assistant VM";
        } else {
            deviceNameInput.placeholder = "Example: UPS Battery Backup";
        }
    }

    if (ipInput) {
        if (selectedType === "physical") {
            ipInput.placeholder = "Example: 192.168.0.55";
        } else if (selectedType === "virtual") {
            ipInput.placeholder = "Example: 192.168.0.41";
        } else {
            ipInput.placeholder = "Example: 192.168.0.50";
        }
    }

    var warningText = "";

    if (deviceName && ONWATCH_EXISTING_DEVICES[deviceName]) {
        warningText = "Device name already exists: " + deviceName;
    }

    var ipOwner = findExistingIpOwner(ipAddress);
    if (!warningText && ipOwner) {
        warningText = ipAddress + " already belongs to " + ipOwner;
    }

    if (!warningText && selectedType === "virtual" && hostedBySelect && hostedBySelect.value) {
        var hostName = hostedBySelect.value;
        var hostType = (ONWATCH_DEVICE_TYPES[hostName] || "").toLowerCase();

        if (hostName === deviceName) {
            warningText = "A virtual machine cannot host itself.";
        } else if (hostType.indexOf("virtual") !== -1 || hostType.indexOf("vm") !== -1) {
            warningText = "A virtual machine cannot be hosted by another virtual machine.";
        }
    }

    if (warningBox) {
        warningBox.textContent = warningText;
        warningBox.classList.toggle("hidden", warningText === "");
    }

    if (submitButton) {
        submitButton.disabled = warningText !== "";
        submitButton.classList.toggle("disabled", warningText !== "");
    }

    updateProvisioningPreview(selectedType, deviceName, ipAddress, switchPortSelect, hostedBySelect, infrastructureRoleSelect, physicalTypeSelect);
}

function updateProvisioningPreview(selectedType, deviceName, ipAddress, switchPortSelect, hostedBySelect, infrastructureRoleSelect, physicalTypeSelect) {
    var previewDeviceName = document.getElementById("previewDeviceName");
    var previewIpAddress = document.getElementById("previewIpAddress");
    var previewClassification = document.getElementById("previewClassification");
    var previewConnection = document.getElementById("previewConnection");
    var previewPath = document.getElementById("previewPath");

    if (previewDeviceName) {
        previewDeviceName.textContent = deviceName || "Waiting for name";
    }

    if (previewIpAddress) {
        previewIpAddress.textContent = ipAddress || "Waiting for IP";
    }

    var classificationText = "Physical Device";
    var connectionText = "Select switch port";
    var pathText = "Network Path: Internet → Cox Modem Gateway → Cisco Edge Router → Cisco Main Switch → " + (deviceName || "New Physical Device");

    if (selectedType === "physical") {
        var physicalType = physicalTypeSelect && physicalTypeSelect.value ? physicalTypeSelect.value : "Endpoint";
        classificationText = physicalType;
        var portText = switchPortSelect && switchPortSelect.selectedIndex > 0
            ? switchPortSelect.options[switchPortSelect.selectedIndex].text
            : "Select switch port";
        connectionText = portText;
    } else if (selectedType === "virtual") {
        classificationText = "Virtual Machine";
        var hostText = hostedBySelect && hostedBySelect.value ? hostedBySelect.value : "Select VM host";
        var inheritedPort = "Inherited port will appear after host selection";

        if (hostedBySelect && hostedBySelect.selectedIndex > 0) {
            var option = hostedBySelect.options[hostedBySelect.selectedIndex];
            inheritedPort = option.getAttribute("data-switch-port") || inheritedPort;
        }

        connectionText = "Hosted By: " + hostText + " | Inherited Port: " + inheritedPort;
        pathText = "Network Path: Internet → Cox Modem Gateway → Cisco Edge Router → Cisco Main Switch → " + hostText + " → " + (deviceName || "New VM");
    } else {
        var roleText = infrastructureRoleSelect && infrastructureRoleSelect.selectedIndex > 0
            ? infrastructureRoleSelect.options[infrastructureRoleSelect.selectedIndex].text
            : "Select infrastructure role";
        classificationText = "Infrastructure";
        connectionText = roleText;
        pathText = "Network Path: Internet → Cox Modem Gateway → Cisco Edge Router → Cisco Main Switch → " + (deviceName || "New Infrastructure Device");
    }

    if (previewClassification) {
        previewClassification.textContent = classificationText;
    }

    if (previewConnection) {
        previewConnection.textContent = connectionText;
    }

    if (previewPath) {
        previewPath.textContent = pathText;
    }
}

function closeProvisionSuccessModal() {
    var modal = document.getElementById("provisionSuccessModal");
    if (modal) {
        modal.classList.add("hidden");
    }
}

document.addEventListener("DOMContentLoaded", function () {
    updateProvisioningFields(true);

    var modal = document.getElementById("provisionSuccessModal");
    if (modal) {
        setTimeout(function () {
            closeProvisionSuccessModal();
        }, 7000);
    }
});
</script>


<script>
(function () {
    function refreshNocCorrelationEngine() {
        fetch("/api/dashboard-data")
            .then(function (response) { return response.json(); })
            .then(function (data) {
                if (!data || !data.noc_correlation) { return; }

                var noc = data.noc_correlation || {};
                var html = data.noc_correlation_html || {};

                setTextIfPresent("nocRootCauseValue", noc.root_cause_count ?? "0");
                setTextIfPresent("nocEndpointIssueValue", noc.endpoint_issue_count ?? "0");
                setTextIfPresent("nocOperationalStateValue", noc.operational_state_count ?? "0");
                setTextIfPresent("nocHealthScoreValue", (noc.health_score ?? "0") + "%");
                setTextIfPresent("nocStateLabel", noc.state_label || "N/A");
                setTextIfPresent("nocRecommendationValue", noc.recommendation || "N/A");
                setHTMLIfPresent("nocCorrelationRows", html.rows || "");
            })
            .catch(function () {});
    }

    refreshNocCorrelationEngine();
    setInterval(refreshNocCorrelationEngine, 30000);
})();
</script>


<!-- PHASE 11D.1 - SMART REFRESH STATE FIX INSTALLED -->

<script>
/* PHASE 11D.1 - SCHEDULED DEVICE BINDING FIX */
document.addEventListener("DOMContentLoaded", function () {
    var scheduledForm = document.querySelector('form[action="/scheduled-maintenance/add"]');
    if (!scheduledForm) {
        return;
    }

    scheduledForm.addEventListener("submit", function (event) {
        var deviceSelect = document.getElementById("scheduledDeviceName");

        if (!deviceSelect || !deviceSelect.value) {
            event.preventDefault();
            alert("Please select the device you want to schedule for maintenance.");
            return false;
        }

        sessionStorage.setItem("onWatchRefreshResume", "1");
        return true;
    });
});
</script>


<script>
/* PHASE 11E - NOC COMMAND CENTER LIVE REFRESH */
(function () {
    function updateNocCommandCenter(data) {
        if (!data || !data.noc_command_center) {
            return;
        }

        var cmd = data.noc_command_center;

        if (typeof setTextIfPresent === "function") {
            setTextIfPresent("nocCommandNetworkState", cmd.network_state || "Unknown");
            setTextIfPresent("nocCommandHealth", (cmd.health_percent ?? 0) + "%");
            setTextIfPresent("nocCommandDevicesUp", cmd.devices_up ?? 0);
            setTextIfPresent("nocCommandCritical", cmd.critical_alerts ?? 0);
            setTextIfPresent("nocCommandMaintenance", cmd.active_maintenance ?? 0);
            setTextIfPresent("nocCommandScheduled", cmd.scheduled_total ?? 0);
            setTextIfPresent("nocCommandCorrelation", (cmd.correlation_score ?? 100) + "%");
            setTextIfPresent("nocCommandCorrelationState", cmd.correlation_state || "Normal");
            setTextIfPresent("nocCommandRecommendation", cmd.top_recommendation || "No action required.");
            setTextIfPresent("nocCommandCorrelationRecommendation", cmd.correlation_recommendation || "");
        }


        var recBox = document.getElementById("nocCommandRecommendations");
        if (recBox && Array.isArray(cmd.recommendations)) {
            recBox.innerHTML = cmd.recommendations.map(function (rec) {
                var priority = (rec.priority || "OK").toLowerCase();
                return "<div class='noc-integrated-item priority-" + priority + "'>" +
                    "<div class='noc-integrated-badge'><span>" + (rec.icon || "🧠") + "</span><strong>" + (rec.badge || rec.priority || "INFO") + "</strong></div>" +
                    "<div><strong>" + (rec.title || "Recommendation") + "</strong><p>" + (rec.message || "No details available.") + "</p></div>" +
                    "</div>";
            }).join("");
        }

        var stateBox = document.querySelector(".noc-command-state");
        if (stateBox) {
            stateBox.className = "noc-command-state " + (cmd.state_class || "good");
        }
    }

    window.updateNocCommandCenter = updateNocCommandCenter;
})();
</script>


<script>
/* PHASE 11G - HISTORICAL INTELLIGENCE LIVE REFRESH */
(function () {
    function updateNocHistoricalIntelligence(data) {
        var hist = null;

        if (data && data.noc_command_center && data.noc_command_center.historical) {
            hist = data.noc_command_center.historical;
        } else if (data && data.noc_historical) {
            hist = data.noc_historical;
        }

        if (!hist) {
            return;
        }

        if (typeof setTextIfPresent === "function") {
            setTextIfPresent("nocHistorySummary", hist.summary || "No historical events recorded yet.");
            setTextIfPresent("nocHistoryTotalEvents", hist.total_events ?? 0);
            setTextIfPresent("nocHistoryTrendCount", hist.trend_count ?? 0);
            setTextIfPresent("nocHistoryTopDevice", hist.top_device || "N/A");
            setTextIfPresent("nocHistoryTopDeviceEvents", (hist.top_device_events ?? 0) + " events");
        }

        if (typeof setHTMLIfPresent === "function") {
            setHTMLIfPresent("nocHistoryTrendList", hist.trend_html || "<div class='noc-history-empty'>No recurring trend detected.</div>");
        }
    }

    window.updateNocHistoricalIntelligence = updateNocHistoricalIntelligence;
})();
</script>

</body>
</html>







